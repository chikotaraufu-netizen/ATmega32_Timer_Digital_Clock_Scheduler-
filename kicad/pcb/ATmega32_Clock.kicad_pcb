  ;; ============================================================
  ;; TRACKS - Key signal connections
  ;; ============================================================

  ;; VCC bus (top of board)
  (segment (start 35 22.86) (end 27 14) (width 0.5) (layer "F.Cu") (net 1) (uuid "t1000001-0000-4000-8000-000000000001"))
  (segment (start 35 22.86) (end 42 14) (width 0.5) (layer "F.Cu") (net 1) (uuid "t1000002-0000-4000-8000-000000000001"))

  ;; GND bus (bottom copper pour would handle this, but explicit traces for key connections)
  (segment (start 35 25.4) (end 16.5 28) (width 0.5) (layer "F.Cu") (net 2) (uuid "t1000003-0000-4000-8000-000000000001"))
  (segment (start 35 25.4) (end 24.5 28) (width 0.5) (layer "F.Cu") (net 2) (uuid "t1000004-0000-4000-8000-000000000001"))

  ;; XTAL1 trace (crystal to MCU pin 13)
  (segment (start 15.56 24) (end 35 30.48) (width 0.25) (layer "F.Cu") (net 10) (uuid "t1000005-0000-4000-8000-000000000001"))

  ;; XTAL2 trace (crystal to MCU pin 12)
  (segment (start 20.44 24) (end 35 27.94) (width 0.25) (layer "F.Cu") (net 11) (uuid "t1000006-0000-4000-8000-000000000001"))

  ;; RESET trace (R1 to MCU pin 9)
  (segment (start 20.16 34) (end 35 20.32) (width 0.25) (layer "F.Cu") (net 12) (uuid "t1000007-0000-4000-8000-000000000001"))

  ;; LED_STATUS (MCU pin 1 to R5)
  (segment (start 35 0) (end 58 10) (width 0.25) (layer "F.Cu") (net 6) (uuid "t1000008-0000-4000-8000-000000000001"))

  ;; LED_TASK (MCU pin 2 to R6)
  (segment (start 35 2.54) (end 66 10) (width 0.25) (layer "F.Cu") (net 7) (uuid "t1000009-0000-4000-8000-000000000001"))

  ;; SET_BTN (MCU pin 40 to SW2)
  (segment (start 50.24 0) (end 58 50) (width 0.25) (layer "B.Cu") (net 3) (uuid "t100000a-0000-4000-8000-000000000001"))

  ;; INC_BTN (MCU pin 39 to SW3)
  (segment (start 50.24 2.54) (end 65 50) (width 0.25) (layer "B.Cu") (net 4) (uuid "t100000b-0000-4000-8000-000000000001"))

  ;; CLOCK_RESET (MCU pin 38 to SW4)
  (segment (start 50.24 5.08) (end 72 50) (width 0.25) (layer "B.Cu") (net 5) (uuid "t100000c-0000-4000-8000-000000000001"))

  ;; USART_TXD (MCU pin 15 to J1)
  (segment (start 35 35.56) (end 74 28) (width 0.25) (layer "F.Cu") (net 8) (uuid "t100000d-0000-4000-8000-000000000001"))

  ;; USART_RXD (MCU pin 14 to J1)
  (segment (start 35 33.02) (end 74 30.54) (width 0.25) (layer "F.Cu") (net 9) (uuid "t100000e-0000-4000-8000-000000000001"))

  ;; MOSI (MCU pin 6 to ISP J2)
  (segment (start 35 12.7) (end 8 50) (width 0.25) (layer "B.Cu") (net 13) (uuid "t100000f-0000-4000-8000-000000000001"))

  ;; MISO (MCU pin 7 to ISP J2)
  (segment (start 35 15.24) (end 10.54 52.54) (width 0.25) (layer "B.Cu") (net 14) (uuid "t1000010-0000-4000-8000-000000000001"))

  ;; SCK (MCU pin 8 to ISP J2)
  (segment (start 35 17.78) (end 10.54 55.08) (width 0.25) (layer "B.Cu") (net 15) (uuid "t1000011-0000-4000-8000-000000000001"))

  ;; ============================================================
  ;; GROUND ZONE (B.Cu pour)
  ;; ============================================================
  (zone
    (net 2)
    (net_name "GND")
    (layer "B.Cu")
    (uuid "z1000001-0000-4000-8000-000000000001")
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.25)
    (filled_areas_thickness no)
    (fill yes (thermal_gap 0.5) (thermal_bridge_width 0.5))
    (polygon
      (pts
        (xy 1 1)
        (xy 79 1)
        (xy 79 59)
        (xy 1 59)
      )
    )
  )
)
