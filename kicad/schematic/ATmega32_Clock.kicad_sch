  ;; ============================================================
  ;; TEXT ANNOTATIONS
  ;; ============================================================

  (text "ATmega32 Timer-Based Digital Clock\n& Task Scheduler\n\nTimer1: CTC Mode\nClock: 8 MHz External Crystal\nPrescaler: 1024\nOCR1A: 7812 (1 Hz interrupt)\n\nStatus LED: Toggles every 2s (PB0)\nTask LED: Flashes every 5s (PB1)\n\nUSART: 9600 baud, 8N1"
    (at 40.64 40.64 0)
    (effects (font (size 2.54 2.54)))
    (uuid "a1b2c3d4-0080-4000-8000-000000000080")
  )

  (text "CLOCK CIRCUIT\n8 MHz Crystal + 22pF Load Caps"
    (at 99.06 68.58 0)
    (effects (font (size 1.524 1.524)))
    (uuid "a1b2c3d4-0081-4000-8000-000000000081")
  )

  (text "RESET CIRCUIT\n10K Pull-up + Push Button"
    (at 106.68 44.45 0)
    (effects (font (size 1.524 1.524)))
    (uuid "a1b2c3d4-0082-4000-8000-000000000082")
  )

  (text "USER BUTTONS\nSET | INCREMENT | RESET\nActive-Low with Pull-ups"
    (at 193.04 109.22 0)
    (effects (font (size 1.524 1.524)))
    (uuid "a1b2c3d4-0083-4000-8000-000000000083")
  )

  (text "STATUS LEDs\nLED_STATUS (2s toggle)\nLED_TASK (5s flash)"
    (at 193.04 68.58 0)
    (effects (font (size 1.524 1.524)))
    (uuid "a1b2c3d4-0084-4000-8000-000000000084")
  )

  (text "ISP PROGRAMMING\nMOSI/MISO/SCK/RST/VCC/GND"
    (at 71.12 72.39 0)
    (effects (font (size 1.524 1.524)))
    (uuid "a1b2c3d4-0085-4000-8000-000000000085")
